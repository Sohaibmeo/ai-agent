{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/workflow-flow.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/workflow-step.ts",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/workflow-flow.ts": {
      "maxDuration": 60,
      "experimentalTriggers": [
        {
          "type": "queue/v2beta",
          "topic": "__wkf_workflow_*"
        }
      ]
    },
    "api/workflow-step.ts": {
      "maxDuration": 300,
      "experimentalTriggers": [
        {
          "type": "queue/v2beta",
          "topic": "__wkf_step_*"
        }
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts",
      "methods": [
        "GET",
        "POST",
        "PUT",
        "PATCH",
        "OPTIONS",
        "DELETE",
        "HEAD",
        "CONNECT",
        "TRACE"
      ]
    }
  ]
}
